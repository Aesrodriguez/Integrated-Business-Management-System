# Puerto local. En Render se inyecta PORT automaticamente.
PORT=3000

# Entorno por defecto para desarrollo local.
# En Render debe quedar como production.
NODE_ENV=development

# Usuario de autenticacion Basic.
BASIC_AUTH_USER=admin

# Clave temporal solo para pruebas o migracion.
# En produccion usa BASIC_AUTH_PASSWORD_HASH.
BASIC_AUTH_PASS=change-me

# Hash PBKDF2-SHA256 recomendado para produccion.
BASIC_AUTH_PASSWORD_HASH=

# Email de la cuenta de servicio de Google Sheets.
GOOGLE_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com

# Pega la clave privada con saltos de linea escapados como \n.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ID exacto de la hoja de calculo destino.
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Rango base de trabajadores. Ajusta solo si cambia la estructura de la hoja.
GOOGLE_SHEETS_WORKERS_RANGE=Trabajadores!A:Z

# TTL de caché en milisegundos.
CACHE_TTL_MS=15000

# Origen exacto del frontend desplegado. Separar por comas si hay mas de uno.
CORS_ALLOWED_ORIGINS=https://integrated-business-management-syst.vercel.app

# Mantener true cuando el servicio esta detras de un proxy como Render.
TRUST_PROXY=true

# Forzar HTTPS en produccion.
FORCE_HTTPS=true
